<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/black">

    <LinearLayout
        android:id="@+id/splash_content"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:padding="24dp">

        <!-- Injected Logo -->
        <ImageView
            android:id="@+id/iv_splash_logo"
            android:layout_width="160dp"
            android:layout_height="160dp"
            android:src="@drawable/img_logo_splash"
            android:layout_marginBottom="48dp"
            android:scaleType="centerCrop"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="READY TO EXECUTE"
            android:textColor="@color/text_tertiary"
            android:textSize="10sp"
            android:letterSpacing="0.2"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Test your edge."
            android:textColor="@color/white"
            android:textSize="44sp"
            android:textStyle="bold"
            android:layout_marginTop="24dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Most strategies look great on paper. Find out if yours\nsurvives 20 years of real market conditions."
            android:textColor="@color/text_secondary"
            android:textSize="14sp"
            android:textAlignment="center"
            android:layout_marginTop="16dp"/>

    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingVertical="32dp"
        android:paddingHorizontal="24dp"
        android:gravity="center"
        app:layout_constraintBottom_toBottomOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ılı  ROOKNOMICS © 2026"
            android:textColor="@color/text_secondary"
            android:textSize="10sp"
            android:textStyle="bold"
            android:letterSpacing="0.2"/>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
