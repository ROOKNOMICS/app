<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_page">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:paddingVertical="32dp"
            android:paddingBottom="64dp">

            <!-- Title Header -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="24dp">
                <View
                    android:layout_width="2dp"
                    android:layout_height="16dp"
                    android:background="@color/emerald_brand"
                    android:layout_marginEnd="8dp"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="SIMULATION ENGINE"
                    android:textColor="@color/text_tertiary"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.2"/>
            </LinearLayout>

            <!-- 1. EQUITY CURVE PANEL -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="@color/surface_card"
                app:cardCornerRadius="4dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/border_color"
                app:strokeWidth="1dp">
                
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="24dp">
                    
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="EQUITY CURVE"
                        android:textColor="@color/text_tertiary"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.2"/>
                        
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Portfolio Value Over Time"
                        android:textColor="@color/white"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:layout_marginTop="8dp"/>

                    <!-- Missing Data Graph Container -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="250dp"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:layout_marginTop="24dp"
                        android:background="@drawable/bg_input">
                        
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="AWAITING SIMULATION DATA"
                            android:textColor="@color/text_tertiary"
                            android:textSize="10sp"
                            android:textStyle="bold"
                            android:letterSpacing="0.1"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Run a backtest to populate the equity curve"
                            android:textColor="@color/text_tertiary"
                            android:textSize="10sp"
                            android:layout_marginTop="8dp"/>
                        
                    </LinearLayout>
                                        
                    <!-- The Real Chart (Hidden until API resolves) -->
                    <com.github.mikephil.charting.charts.LineChart
                        android:id="@+id/line_chart"
                        android:layout_width="match_parent"
                        android:layout_height="250dp"
                        android:layout_marginTop="24dp"
                        android:visibility="gone"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 2. TRADE LOG PANEL -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="@color/surface_card"
                app:cardCornerRadius="4dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/border_color"
                app:strokeWidth="1dp">
                
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingTop="24dp"
                    android:paddingBottom="24dp">
                    
                    <!-- Tab Header Log -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="24dp"
                        android:layout_marginBottom="24dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="TRADE LOG"
                            android:textColor="@color/text_secondary"
                            android:textSize="12sp"
                            android:letterSpacing="0.2"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="8 TRADES"
                            android:textColor="@color/emerald_brand"
                            android:textSize="10sp"
                            android:textStyle="bold"
                            android:background="@drawable/bg_input"
                            android:paddingHorizontal="8dp"
                            android:paddingVertical="4dp"
                            android:layout_marginStart="16dp"/>
                    </LinearLayout>
                    
                    <!-- Table Header Layout -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:paddingHorizontal="24dp"
                        android:paddingBottom="16dp">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="DATE" android:textColor="@color/text_tertiary" android:textSize="10sp" android:textStyle="bold" android:letterSpacing="0.1"/>
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="ACTION" android:textColor="@color/text_tertiary" android:textSize="10sp" android:textStyle="bold" android:letterSpacing="0.1"/>
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="PRICE" android:textColor="@color/text_tertiary" android:textSize="10sp" android:textStyle="bold" android:letterSpacing="0.1"/>
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="P&amp;L" android:textColor="@color/text_tertiary" android:textSize="10sp" android:textStyle="bold" android:letterSpacing="0.1"/>
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1.2" android:text="CUMULATIVE" android:textColor="@color/text_tertiary" android:textSize="10sp" android:textStyle="bold" android:letterSpacing="0.1"/>
                    </LinearLayout>
                    
                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/border_color"/>

                    <!-- Mock Row 1 -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:paddingHorizontal="24dp" android:paddingVertical="16dp">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Jan 2004" android:textColor="@color/text_secondary" android:textSize="10sp"/>
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="BUY" android:textColor="#60A5FA" android:textSize="10sp" android:textStyle="bold"/>
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="$111.25" android:textColor="@color/text_primary" android:textSize="10sp"/>
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="—" android:textColor="@color/text_secondary" android:textSize="10sp"/>
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1.2" android:text="$10,000" android:textColor="@color/white" android:textSize="10sp" android:textStyle="bold"/>
                    </LinearLayout>
                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/border_color"/>

                    <!-- Mock Row 2 -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:paddingHorizontal="24dp" android:paddingVertical="16dp">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Mar 2004" android:textColor="@color/text_secondary" android:textSize="10sp"/>
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="SELL" android:textColor="@color/white" android:textSize="10sp" android:textStyle="bold"/>
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="$114.80" android:textColor="@color/text_primary" android:textSize="10sp"/>
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="+$316" android:textColor="@color/emerald_brand" android:textSize="10sp"/>
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1.2" android:text="$10,316" android:textColor="@color/white" android:textSize="10sp" android:textStyle="bold"/>
                    </LinearLayout>
                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/border_color"/>
                    
                    <!-- Mock Row 3 -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:paddingHorizontal="24dp" android:paddingVertical="16dp">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Jan 2008" android:textColor="@color/text_secondary" android:textSize="10sp"/>
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="SELL" android:textColor="@color/white" android:textSize="10sp" android:textStyle="bold"/>
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="$138.70" android:textColor="@color/text_primary" android:textSize="10sp"/>
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="-$993" android:textColor="#EF4444" android:textSize="10sp"/>
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1.2" android:text="$10,216" android:textColor="@color/white" android:textSize="10sp" android:textStyle="bold"/>
                    </LinearLayout>
                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/border_color"/>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 3. METRICS PANEL -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="@color/surface_card"
                app:cardCornerRadius="4dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/border_color"
                app:strokeWidth="1dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingTop="24dp">
                    
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="METRICS"
                        android:textColor="@color/text_tertiary"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.2"
                        android:layout_marginHorizontal="24dp"/>

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginHorizontal="24dp"
                        android:layout_marginTop="16dp"
                        android:layout_marginBottom="24dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="STRATEGY"
                            android:textColor="@color/emerald_brand"
                            android:textSize="10sp"
                            android:textStyle="bold"
                            android:paddingHorizontal="16dp"
                            android:paddingVertical="8dp"
                            android:background="@drawable/bg_input"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="S&amp;P 500"
                            android:textColor="@color/text_tertiary"
                            android:textSize="10sp"
                            android:paddingHorizontal="16dp"
                            android:paddingVertical="8dp"/>
                    </LinearLayout>
                    
                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/border_color"/>
                    <!-- Metric Row 1 -->
                    <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:padding="20dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="TOTAL RETURN" android:textColor="@color/text_secondary" android:textSize="10sp" android:letterSpacing="0.1" android:layout_alignParentStart="true"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0" android:textColor="@color/white" android:textSize="12sp" android:textStyle="bold" android:layout_alignParentEnd="true"/>
                    </RelativeLayout>
                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/border_color"/>
                    <!-- Metric Row 2 -->
                    <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:padding="20dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="ANNUALIZED" android:textColor="@color/text_secondary" android:textSize="10sp" android:letterSpacing="0.1" android:layout_alignParentStart="true"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0" android:textColor="@color/white" android:textSize="12sp" android:textStyle="bold" android:layout_alignParentEnd="true"/>
                    </RelativeLayout>
                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/border_color"/>
                    <!-- Metric Row 3 -->
                    <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:padding="20dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="MAX DRAWDOWN" android:textColor="@color/text_secondary" android:textSize="10sp" android:letterSpacing="0.1" android:layout_alignParentStart="true"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0" android:textColor="@color/white" android:textSize="12sp" android:textStyle="bold" android:layout_alignParentEnd="true"/>
                    </RelativeLayout>
                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/border_color"/>
                    <!-- Metric Row 4 -->
                    <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:padding="20dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="WIN RATE" android:textColor="@color/text_secondary" android:textSize="10sp" android:letterSpacing="0.1" android:layout_alignParentStart="true"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="—" android:textColor="@color/white" android:textSize="12sp" android:textStyle="bold" android:layout_alignParentEnd="true"/>
                    </RelativeLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 4. VERDICT PANEL -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="@color/surface_card"
                app:cardCornerRadius="4dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/border_color"
                app:strokeWidth="1dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="24dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="VERDICT"
                        android:textColor="@color/text_tertiary"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.2"/>
                        
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:background="#1A332200"
                        android:text="UNDERPERFORMED"
                        android:textColor="#FBBF24"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:padding="16dp"
                        android:gravity="center_vertical"
                        android:letterSpacing="0.05"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 5. RISK PROFILE PANEL -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="@color/surface_card"
                app:cardCornerRadius="4dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/border_color"
                app:strokeWidth="1dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="24dp">
                    
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="The strategy trails the benchmark by 0.00 percentage points."
                        android:textColor="@color/white"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="24dp"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">
                        
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:padding="16dp"
                            android:background="@drawable/bg_input"
                            android:layout_marginEnd="8dp">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="STRATEGY" android:textColor="@color/text_secondary" android:textSize="10sp" android:letterSpacing="0.1"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0.00%" android:textColor="@color/white" android:textSize="20sp" android:textStyle="bold" android:layout_marginTop="16dp"/>
                        </LinearLayout>
                        
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:padding="16dp"
                            android:background="@drawable/bg_input"
                            android:layout_marginStart="8dp">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="S&amp;P 500" android:textColor="@color/text_secondary" android:textSize="10sp" android:letterSpacing="0.1"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0.00%" android:textColor="#FBBF24" android:textSize="20sp" android:textStyle="bold" android:layout_marginTop="16dp"/>
                        </LinearLayout>
                    </LinearLayout>

                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/border_color" android:layout_marginVertical="24dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="RISK PROFILE"
                        android:textColor="@color/text_tertiary"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.2"/>

                    <!-- MPAndroidChart RadarChart Instance for the pentagram -->
                    <com.github.mikephil.charting.charts.RadarChart
                        android:id="@+id/radar_chart"
                        android:layout_width="match_parent"
                        android:layout_height="250dp"
                        android:layout_marginTop="16dp"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="24dp">
                        
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:background="@drawable/bg_input" android:gravity="center" android:padding="16dp" android:layout_marginEnd="4dp">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="BETA" android:textColor="@color/text_secondary" android:textSize="10sp" android:letterSpacing="0.1"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0.00" android:textColor="@color/white" android:textSize="12sp" android:textStyle="bold" android:layout_marginTop="8dp"/>
                        </LinearLayout>
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:background="@drawable/bg_input" android:gravity="center" android:padding="16dp" android:layout_marginHorizontal="4dp">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="ALPHA" android:textColor="@color/text_secondary" android:textSize="10sp" android:letterSpacing="0.1"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0.0%" android:textColor="@color/white" android:textSize="12sp" android:textStyle="bold" android:layout_marginTop="8dp"/>
                        </LinearLayout>
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:background="@drawable/bg_input" android:gravity="center" android:padding="16dp" android:layout_marginStart="4dp">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="VAR (5%)" android:textColor="@color/text_secondary" android:textSize="10sp" android:letterSpacing="0.1"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0.0%" android:textColor="@color/white" android:textSize="12sp" android:textStyle="bold" android:layout_marginTop="8dp"/>
                        </LinearLayout>
                    </LinearLayout>
                    
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </ScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>
