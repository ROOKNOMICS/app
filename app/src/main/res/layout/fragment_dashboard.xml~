<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_page">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">
        
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="64dp">

            <!-- Top Header containing Avatar -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="24dp">
                
                <TextView
                    android:id="@+id/tv_system_active"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="SYSTEM ACTIVE  •"
                    android:textSize="12sp"
                    android:letterSpacing="0.2"
                    android:textColor="@color/text_secondary"
                    android:layout_centerVertical="true"/>

                <!-- Profile Avatar -->
                <TextView
                    android:id="@+id/btn_profile"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:background="@drawable/bg_circle_avatar"
                    android:text="J"
                    android:textColor="@color/emerald_text"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"/>
            </RelativeLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="BEAT THE\nINDEX."
                android:textColor="@color/text_primary"
                android:textSize="56sp"
                android:textStyle="bold"
                android:lineSpacingExtra="-8dp"
                android:layout_marginTop="8dp"
                android:layout_marginHorizontal="24dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="OUTPERFORM IF YOU CAN."
                android:textColor="@color/gold_brand"
                android:textSize="26sp"
                android:textStyle="bold"
                android:layout_marginTop="16dp"
                android:layout_marginHorizontal="24dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Test your strategy against decades of market data."
                android:textColor="@color/text_secondary"
                android:textSize="16sp"
                android:layout_marginTop="16dp"
                android:layout_marginStart="24dp"
                android:layout_marginEnd="64dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="32dp"
                android:layout_marginHorizontal="24dp">
                
                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btn_to_builder"
                    android:layout_width="0dp"
                    android:layout_height="60dp"
                    android:layout_weight="1.2"
                    android:background="@color/gold_brand"
                    android:text="RUN SIMULATION  →"
                    android:textColor="@color/black"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btn_view_demo"
                    android:layout_width="0dp"
                    android:layout_height="60dp"
                    android:layout_weight="1"
                    android:layout_marginStart="16dp"
                    android:background="@drawable/bg_input"
                    android:text="▷ VIEW DEMO"
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp"
                    android:textStyle="bold" />
            </LinearLayout>
                
            <!-- Top Status Grid -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="32dp"
                android:paddingHorizontal="24dp">
                
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="DATA RANGE"
                        android:textColor="@color/text_secondary"
                        android:textSize="10sp"
                        android:letterSpacing="0.1"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="2000 - 2024"
                        android:textColor="@color/text_primary"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:layout_marginTop="4dp"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="ENGINE"
                        android:textColor="@color/text_secondary"
                        android:textSize="10sp"
                        android:letterSpacing="0.1"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="LIVE •"
                        android:textColor="@color/gold_brand"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:layout_marginTop="4dp"/>
                </LinearLayout>
                
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="LATENCY"
                        android:textColor="@color/text_secondary"
                        android:textSize="10sp"
                        android:letterSpacing="0.1"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="&lt;1MS"
                        android:textColor="@color/text_primary"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:layout_marginTop="4dp"/>
                </LinearLayout>
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/border_color"
                android:layout_marginHorizontal="24dp"
                android:layout_marginVertical="32dp"/>

            <!-- ACCUMULATION BLOCK -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="THE ACCUMULATION"
                android:textColor="@color/text_tertiary"
                android:textSize="10sp"
                android:letterSpacing="0.2"
                android:layout_marginHorizontal="24dp"
                android:layout_marginTop="32dp"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Growth through\ncalculated patience."
                android:textColor="@color/white"
                android:textSize="36sp"
                android:textStyle="bold"
                android:lineSpacingExtra="-6dp"
                android:layout_marginHorizontal="24dp"/>

            <ImageView
                android:id="@+id/iv_gold_coins"
                android:layout_width="160dp"
                android:layout_height="160dp"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="32dp"
                android:src="@drawable/img_gold_coins"
                android:scaleType="centerCrop"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="True wealth is not built on impulse. It is engineered through systematic compounding, risk-adjusted parameters, and the refusal to succumb to emotional variance."
                android:textColor="@color/text_secondary"
                android:textSize="14sp"
                android:lineSpacingExtra="4dp"
                android:layout_marginHorizontal="24dp"
                android:layout_marginTop="24dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginHorizontal="24dp"
                android:layout_marginTop="32dp">
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="YIELD GOAL"
                        android:textColor="@color/text_secondary"
                        android:textSize="10sp"
                        android:letterSpacing="0.1"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="+14.2%"
                        android:textColor="@color/gold_brand"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:layout_marginTop="4dp"/>
                </LinearLayout>
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="TIME HORIZON"
                        android:textColor="@color/text_secondary"
                        android:textSize="10sp"
                        android:letterSpacing="0.1"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="LONG"
                        android:textColor="@color/white"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:layout_marginTop="4dp"/>
                </LinearLayout>
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="VARIANCE"
                        android:textColor="@color/text_secondary"
                        android:textSize="10sp"
                        android:letterSpacing="0.1"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="LOW"
                        android:textColor="@color/white"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:layout_marginTop="4dp"/>
                </LinearLayout>
            </LinearLayout>

            <androidx.appcompat.widget.AppCompatButton
                android:layout_width="wrap_content"
                android:layout_height="44dp"
                android:layout_marginHorizontal="24dp"
                android:layout_marginTop="32dp"
                android:background="@drawable/bg_input"
                android:paddingHorizontal="24dp"
                android:text="SIMULATE RETURNS  →"
                android:textColor="@color/gold_brand"
                android:textSize="12sp"
                android:textStyle="bold" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/border_color"
                android:layout_marginHorizontal="24dp"
                android:layout_marginVertical="32dp"/>

            <!-- NEW OUTPERFORM SECTION -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="THE INSTRUMENT"
                android:textColor="@color/text_tertiary"
                android:textSize="10sp"
                android:letterSpacing="0.2"
                android:layout_marginHorizontal="24dp"
                android:layout_marginTop="32dp"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Built for those\nwho outperform."
                android:textColor="@color/white"
                android:textSize="44sp"
                android:textStyle="bold"
                android:lineSpacingExtra="-6dp"
                android:layout_marginHorizontal="24dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Every decision made by elite traders demands tools engineered to match. Precision-grade. Minimal. Uncompromising."
                android:textColor="@color/text_secondary"
                android:textSize="14sp"
                android:lineSpacingExtra="4dp"
                android:layout_marginHorizontal="24dp"
                android:layout_marginTop="16dp"/>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/border_color"
                android:layout_marginHorizontal="24dp"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="24dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="▪  INSTITUTIONAL-GRADE EXECUTION\n\n▪  REAL-TIME MARKET DATA FEEDS\n\n▪  RISK-ADJUSTED POSITION SIZING\n\n▪  ZERO-LATENCY SIGNAL ROUTING"
                android:textColor="@color/text_secondary"
                android:textSize="10sp"
                android:letterSpacing="0.1"
                android:textStyle="bold"
                android:layout_marginHorizontal="24dp"/>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/border_color"
                android:layout_marginHorizontal="24dp"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="24dp"/>

            <!-- 2x2 Grid for Elite -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginHorizontal="24dp">
                
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="MEMBERS"
                            android:textColor="@color/text_secondary"
                            android:textSize="10sp"
                            android:letterSpacing="0.1"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="ELITE ONLY"
                            android:textColor="@color/white"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:layout_marginTop="4dp"/>
                    </LinearLayout>
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="RETURNS"
                            android:textColor="@color/text_secondary"
                            android:textSize="10sp"
                            android:letterSpacing="0.1"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="VERIFIED"
                            android:textColor="@color/text_primary"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:layout_marginTop="4dp"/>
                    </LinearLayout>
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/border_color"
                    android:layout_marginVertical="16dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="UPTIME"
                            android:textColor="@color/text_secondary"
                            android:textSize="10sp"
                            android:letterSpacing="0.1"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="99.99%"
                            android:textColor="@color/white"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:layout_marginTop="4dp"/>
                    </LinearLayout>
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="SUPPORT"
                            android:textColor="@color/text_secondary"
                            android:textSize="10sp"
                            android:letterSpacing="0.1"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="24 / 7"
                            android:textColor="@color/white"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:layout_marginTop="4dp"/>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <!-- Physical Elite Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="220dp"
                android:layout_marginHorizontal="24dp"
                android:layout_marginTop="32dp"
                app:cardBackgroundColor="@color/surface_card"
                app:cardCornerRadius="16dp"
                app:strokeColor="@color/border_color"
                app:strokeWidth="1dp">
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:padding="24dp">
                    
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="ROOKNOMICS"
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.2"/>
                        
                    <!-- Emulated Chip -->
                    <View
                        android:layout_width="100dp"
                        android:layout_height="100dp"
                        android:background="@drawable/img"
                        android:layout_marginTop="40dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="•••• •••• •••• ••••"
                        android:layout_marginTop="23dp"
                        android:textColor="@color/text_secondary"
                        android:textSize="18sp"
                        android:layout_alignParentBottom="true"
                        android:layout_marginBottom="16dp"/>

                    <!-- Emulated Mastercard Logo -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_alignParentEnd="true"
                        android:layout_alignParentBottom="true"
                        android:layout_marginBottom="16dp">
                        <View android:layout_width="16dp" android:layout_height="16dp" android:background="@drawable/bg_circle_avatar" android:backgroundTint="@color/gold_brand" android:alpha="0.8"/>
                        <View android:layout_width="16dp" android:layout_height="16dp" android:background="@drawable/bg_circle_avatar" android:backgroundTint="#FFD700" android:alpha="0.6" android:layout_marginStart="-8dp"/>
                    </LinearLayout>
                </RelativeLayout>
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ROOKNOMICS BLACK - ELITE     • ACTIVE"
                android:textColor="@color/text_tertiary"
                android:textSize="10sp"
                android:textStyle="bold"
                android:letterSpacing="0.1"
                android:layout_marginHorizontal="24dp"
                android:layout_marginTop="16dp"/>

            <!-- PRECISION BLOCK -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Built for precision.\nNot decoration."
                android:textColor="@color/white"
                android:textSize="36sp"
                android:textStyle="bold"
                android:lineSpacingExtra="-6dp"
                android:layout_marginHorizontal="24dp"
                android:layout_marginTop="48dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginHorizontal="24dp"
                android:layout_marginTop="32dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:padding="16dp"
                        android:background="@drawable/bg_input">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="BACKTESTING" android:textColor="@color/emerald_brand" android:textSize="10sp" android:letterSpacing="0.1" android:textStyle="bold"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Simulation Engine" android:textColor="@color/white" android:textSize="14sp" android:textStyle="bold" android:layout_marginTop="16dp"/>
                    </LinearLayout>
                    <View android:layout_width="16dp" android:layout_height="match_parent"/>
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:padding="16dp"
                        android:background="@drawable/bg_input">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="COMPARISON" android:textColor="@color/text_tertiary" android:textSize="10sp" android:letterSpacing="0.1"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Index Benchmark" android:textColor="@color/white" android:textSize="14sp" android:textStyle="bold" android:layout_marginTop="16dp"/>
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="16dp">
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:padding="16dp"
                        android:background="@drawable/bg_input">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="RISK PROFILE" android:textColor="@color/text_tertiary" android:textSize="10sp" android:letterSpacing="0.1"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Risk Metrics" android:textColor="@color/white" android:textSize="14sp" android:textStyle="bold" android:layout_marginTop="16dp"/>
                    </LinearLayout>
                    <View android:layout_width="16dp" android:layout_height="match_parent"/>
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:padding="16dp"
                        android:background="@drawable/bg_input">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="RULE ENGINE" android:textColor="@color/text_tertiary" android:textSize="10sp" android:letterSpacing="0.1"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Logic Builder" android:textColor="@color/white" android:textSize="14sp" android:textStyle="bold" android:layout_marginTop="16dp"/>
                    </LinearLayout>
                </LinearLayout>

            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/border_color"
                android:layout_marginHorizontal="24dp"
                android:layout_marginVertical="48dp"/>

            <!-- PIPELINE BLOCK -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="PROTOCOL"
                android:textColor="@color/text_tertiary"
                android:textSize="10sp"
                android:letterSpacing="0.2"
                android:layout_marginHorizontal="24dp"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Execution\nPipeline."
                android:textColor="@color/white"
                android:textSize="44sp"
                android:textStyle="bold"
                android:lineSpacingExtra="-6dp"
                android:layout_marginHorizontal="24dp"/>

            <!-- Steps -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginHorizontal="24dp"
                android:layout_marginTop="32dp">

                <!-- Step 1 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <TextView android:layout_width="32dp" android:layout_height="32dp" android:text="01" android:textSize="12sp" android:textColor="@color/gold_brand" android:background="@drawable/bg_input" android:gravity="center" android:textStyle="bold"/>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:layout_marginStart="16dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="CONFIGURE" android:textColor="@color/text_tertiary" android:textSize="10sp" android:letterSpacing="0.2"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Define Your Rules" android:textColor="@color/white" android:textSize="18sp" android:textStyle="bold" android:layout_marginTop="8dp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Establish trigger thresholds, crossover periods, and risk caps." android:textColor="@color/text_secondary" android:textSize="14sp" android:layout_marginTop="8dp" android:lineSpacingExtra="2dp"/>
                    </LinearLayout>
                </LinearLayout>
                <View android:layout_width="1dp" android:layout_height="40dp" android:background="@color/border_color" android:layout_marginStart="16dp" android:layout_marginVertical="8dp"/>

                <!-- Step 2 -->
                <LinearLayout
                    android:layout_width="match_parent"
