<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_page">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/btn_run_simulation_builder">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <!-- Header info -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="= 2,347 TRADING DAYS  •  AAPL"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                android:letterSpacing="0.1"
                android:layout_marginBottom="24dp"/>

            <!-- Momentum Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                app:cardBackgroundColor="@color/surface_card"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/border_color"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="MOMENTUM RULE  —  RSI"
                            android:textColor="@color/text_primary"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:letterSpacing="0.1"/>

                        <androidx.appcompat.widget.SwitchCompat
                            android:id="@+id/switch_momentum"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:checked="true"
                            app:thumbTint="@color/emerald_text"
                            app:trackTint="#1A4ADE80"/>
                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginVertical="16dp"
                        android:background="@color/border_color"/>

                    <!-- Sliders -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="RSI Period days"
                            android:textColor="@color/text_secondary"
                            android:textSize="12sp"/>
                        <TextView
                            android:id="@+id/tv_rsi_period_val"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="14"
                            android:textColor="@color/emerald_brand"
                            android:textSize="14sp"
                            android:textStyle="bold"/>
                    </LinearLayout>

                    <com.google.android.material.slider.Slider
                        android:id="@+id/slider_rsi_period"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:valueFrom="1.0"
                        android:valueTo="50.0"
                        android:value="14.0"
                        app:tickVisible="false"
                        app:thumbColor="@color/emerald_text"
                        app:trackColorActive="@color/emerald_text"
                        app:trackColorInactive="@color/border_color"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="8dp">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_marginEnd="8dp">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:gravity="center_vertical">
                                <TextView
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:text="Buy Below (Oversold)"
                                    android:textColor="@color/text_secondary"
                                    android:textSize="12sp"/>
                                <TextView
                                    android:id="@+id/tv_rsi_buy_val"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="30"
                                    android:textColor="@color/emerald_brand"
                                    android:textSize="14sp"
                                    android:textStyle="bold"/>
                            </LinearLayout>

                            <com.google.android.material.slider.Slider
                                android:id="@+id/slider_rsi_buy"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:valueFrom="0.0"
                                android:valueTo="50.0"
                                android:value="30.0"
                                app:tickVisible="false"
                                app:thumbColor="@color/emerald_text"
                                app:trackColorActive="@color/emerald_text"
                                app:trackColorInactive="@color/border_color"/>
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_marginStart="8dp">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:gravity="center_vertical">
                                <TextView
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:text="Sell Above (Overbought)"
                                    android:textColor="@color/text_secondary"
                                    android:textSize="12sp"/>
                                <TextView
                                    android:id="@+id/tv_rsi_sell_val"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="70"
                                    android:textColor="#EF4444"
                                    android:textSize="14sp"
                                    android:textStyle="bold"/>
                            </LinearLayout>

                            <com.google.android.material.slider.Slider
                                android:id="@+id/slider_rsi_sell"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:valueFrom="50.0"
                                android:valueTo="100.0"
                                android:value="70.0"
                                app:tickVisible="false"
                                app:thumbColor="@color/emerald_text"
                                app:trackColorActive="@color/emerald_text"
                                app:trackColorInactive="@color/border_color"/>
                        </LinearLayout>
                    </LinearLayout>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="BUY when RSI &lt; 30 (oversold signal). SELL when RSI &gt; 70 (overbought signal)."
                        android:textColor="@color/text_tertiary"
                        android:textSize="12sp"
                        android:layout_marginTop="12dp"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Trend Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                app:cardBackgroundColor="@color/surface_card"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/border_color"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="TREND RULE  —  MA Crossover"
                            android:textColor="@color/text_primary"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:letterSpacing="0.1"/>

                        <androidx.appcompat.widget.SwitchCompat
                            android:id="@+id/switch_trend"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:checked="true"
                            app:thumbTint="@color/emerald_text"
                            app:trackTint="#1A4ADE80"/>
                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginVertical="16dp"
                        android:background="@color/border_color"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="MA TYPE"
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp"
                        android:layout_marginBottom="8dp"/>

                    <Spinner
                        android:id="@+id/spinner_ma_type"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:background="@drawable/bg_input"
                        android:paddingHorizontal="16dp"
                        android:layout_marginBottom="16dp"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_marginEnd="8dp">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:gravity="center_vertical">
                                <TextView
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:text="Short Period days"
                                    android:textColor="@color/text_secondary"
                                    android:textSize="12sp"/>
                                <TextView
                                    android:id="@+id/tv_ma_short_val"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="50"
                                    android:textColor="@color/emerald_brand"
                                    android:textSize="14sp"
                                    android:textStyle="bold"/>
                            </LinearLayout>

                            <com.google.android.material.slider.Slider
                                android:id="@+id/slider_ma_short"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:valueFrom="1.0"
                                android:valueTo="100.0"
                                android:value="50.0"
                                app:tickVisible="false"
                                app:thumbColor="@color/emerald_text"
                                app:trackColorActive="@color/emerald_text"
                                app:trackColorInactive="@color/border_color"/>
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_marginStart="8dp">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:gravity="center_vertical">
                                <TextView
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:text="Long Period days"
                                    android:textColor="@color/text_secondary"
                                    android:textSize="12sp"/>
                                <TextView
                                    android:id="@+id/tv_ma_long_val"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="200"
                                    android:textColor="@color/emerald_brand"
                                    android:textSize="14sp"
                                    android:textStyle="bold"/>
                            </LinearLayout>

                            <com.google.android.material.slider.Slider
                                android:id="@+id/slider_ma_long"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:valueFrom="50.0"
                                android:valueTo="300.0"
                                android:value="200.0"
                                app:tickVisible="false"
                                app:thumbColor="@color/emerald_text"
                                app:trackColorActive="@color/emerald_text"
                                app:trackColorInactive="@color/border_color"/>
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Risk Management Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                app:cardBackgroundColor="@color/surface_card"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/border_color"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="RISK MANAGEMENT"
                        android:textColor="@color/text_primary"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.1"
                        android:layout_marginBottom="16dp"/>

                    <com.google.android.material.checkbox.MaterialCheckBox
                        android:id="@+id/cb_stop_loss"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Stop-Loss (Auto-exit on position loss)"
                        android:textColor="@color/text_secondary"
                        android:textSize="14sp"
                        app:buttonTint="@color/emerald_text"/>

                    <com.google.android.material.checkbox.MaterialCheckBox
                        android:id="@+id/cb_take_profit"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Take-Profit (Auto-exit on gain target)"
                        android:textColor="@color/text_secondary"
                        android:textSize="14sp"
                        android:layout_marginTop="8dp"
                        app:buttonTint="@color/emerald_text"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Rule Summary Box -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="16dp"
                android:background="@drawable/bg_input"
                android:layout_marginBottom="24dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="CAPITAL"
                        android:textColor="@color/text_secondary"
                        android:textSize="10sp"
                        android:letterSpacing="0.1"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="$10,000"
                        android:textColor="@color/text_primary"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:layout_marginTop="4dp"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="PERIOD"
                        android:textColor="@color/text_secondary"
                        android:textSize="10sp"
                        android:letterSpacing="0.1"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="2015 - 2023"
                        android:textColor="@color/text_primary"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:layout_marginTop="4dp"/>
                </LinearLayout>
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <!-- Bottom Action Area -->
    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/btn_run_simulation_builder"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginHorizontal="24dp"
        android:layout_marginBottom="24dp"
        android:background="#4ADE80"
        android:text="▷ RUN SIMULATION"
        android:textColor="@color/black"
        android:textSize="16sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>